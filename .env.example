# PostgreSQL — used by Drizzle ORM
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Cashfree Payments — https://merchant.cashfree.com/merchants/developer/api
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Webhooks — Discord channel webhook URLs
CONTACT_WEBHOOK_URL=
DISCORD_ENTERPRISE_WEBHOOK_URL=
DISCORD_FEATURE_WEBHOOK_URL=
DISCORD_FEEDBACK_WEBHOOK_URL=

# Site
SITE_URL=https://bulkctc.com

# IndexNow — https://www.indexnow.org
INDEXNOW_KEY=

# Chatbase (optional) — https://www.chatbase.co
NEXT_PUBLIC_CHATBOT_ID=
NEXT_PUBLIC_CHATBASE_HOST=
